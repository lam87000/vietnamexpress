<div class="admin-page-header">
  <h1 class="admin-page-title">Fermetures exceptionnelles</h1>
  <p class="admin-page-subtitle">Planifiez vos congés et communiquez sur le site.</p>
</div>

<div class="admin-control-panel">
  <h3>Planifier une fermeture</h3>
  <p class="admin-panel-help">Les dates sélectionnées seront affichées sur toutes les pages.</p>

  <%= form_with model: @closure, url: admin_closures_path, method: :post, class: "closure-form", local: true do |f| %>
    <div class="closure-form-grid">
      <div>
        <%= f.label :start_on, "Début" %>
        <%= f.date_field :start_on, required: true, class: "form-control" %>
      </div>
      <div>
        <%= f.label :end_on, "Fin" %>
        <%= f.date_field :end_on, required: true, class: "form-control" %>
      </div>
      <div>
        <%= f.label :reason, "Motif" %>
        <%= f.text_field :reason, placeholder: "Congés annuels…", class: "form-control" %>
      </div>
      <div class="closure-form-actions">
        <%= f.submit "Planifier la fermeture", class: "admin-btn admin-btn-warning" %>
      </div>
    </div>
  <% end %>
</div>

<div class="admin-control-panel">
  <h3>Fermetures programmées</h3>
  <% if @closures.any? %>
    <div class="closure-list">
      <% @closures.each do |closure| %>
        <div class="closure-item">
          <div>
            <strong><%= closure.formatted_range %></strong>
            <% if closure.reason.present? %>
              <span class="closure-reason">— <%= closure.reason %></span>
            <% end %>
          </div>
          <div class="closure-actions">
            <%= form_with model: closure, url: admin_closure_path(closure), method: :patch, class: "d-inline closure-edit-form", local: true do |f| %>
              <%= f.date_field :start_on, value: closure.start_on, class: "form-control form-control-sm" %>
              <%= f.date_field :end_on, value: closure.end_on, class: "form-control form-control-sm" %>
              <%= f.text_field :reason, value: closure.reason, class: "form-control form-control-sm" %>
              <%= f.submit "Mettre à jour", class: "admin-btn admin-btn-sm" %>
            <% end %>
            <%= button_to "Supprimer", admin_closure_path(closure), method: :delete, data: { turbo_confirm: "Supprimer cette fermeture ?" }, class: "admin-btn admin-btn-danger admin-btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>Aucune fermeture planifiée.</p>
  <% end %>
</div>
