<!-- Menu Section -->
<section id="menu" class="menu-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto text-center mb-5">
        <h2 class="section-title" data-aos="fade-up">Notre Menu Complet</h2>
        <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">
          Découvrez notre carte complète de spécialités vietnamiennes, préparées selon les traditions authentiques.
          <br><small class="text-muted">💡 Cliquez sur un plat pour le commander directement</small>
        </p>
      </div>
    </div>
    
    <div class="menu-tabs" data-aos="fade-up" data-aos-delay="200">
      <ul class="nav nav-pills justify-content-center mb-5" id="menuTabs" role="tablist">
        <% @categories.each_with_index do |category, index| %>
          <li class="nav-item" role="presentation">
            <button class="nav-link <%= 'active' if index == 0 %>" id="<%= category.name.downcase.gsub(' ', '-') %>-tab" data-bs-toggle="pill" data-bs-target="#<%= category.name.downcase.gsub(' ', '-') %>" type="button" role="tab">
              <% if category.name == "Entrées" %>
                <i class="fas fa-utensils me-2"></i>
              <% elsif category.name == "Plats en soupe" %>
                <i class="fas fa-bowl-hot me-2"></i>
              <% elsif category.name == "Plats" %>
                <i class="fas fa-plate-wheat me-2"></i>
              <% elsif category.name == "Garnitures au choix" %>
                <i class="fas fa-leaf me-2"></i>
              <% else %>
                <i class="fas fa-ice-cream me-2"></i>
              <% end %>
              <%= category.name %>
            </button>
          </li>
        <% end %>
      </ul>
    </div>
    
    <div class="tab-content" id="menuTabsContent">
      <% @categories.each_with_index do |category, category_index| %>
        <div class="tab-pane fade <%= 'show active' if category_index == 0 %>" id="<%= category.name.downcase.gsub(' ', '-') %>" role="tabpanel">
          <div class="row g-4">
            <% category.plats.available.each_with_index do |plat, plat_index| %>
              <div class="col-md-6">
                <div class="menu-item clickable-plat" 
                     data-aos="<%= plat_index.even? ? 'fade-right' : 'fade-left' %>"
                     data-plat-url="<%= new_commande_path(plat_id: plat.id) %>">
                  <div class="menu-item-info">
                    <h5 class="menu-item-name">
                      <%= plat.nom %>
                      <i class="fas fa-arrow-right menu-item-arrow"></i>
                    </h5>
                    <p class="menu-item-description"><%= plat.description %></p>
                  </div>
                  <div class="menu-item-price"><%= plat.formatted_price %></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

