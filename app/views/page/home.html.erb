<script>
  // Gestion des clics sur les plats du menu
  document.addEventListener('DOMContentLoaded', function() {
    const clickablePlats = document.querySelectorAll('.clickable-plat');
    
    clickablePlats.forEach(plat => {
      plat.addEventListener('click', function(e) {
        // Effet visuel de feedback
        this.style.transform = 'scale(0.98)';
        
        // Redirection vers la page de commande
        const url = this.getAttribute('data-plat-url');
        if (url) {
          setTimeout(() => {
            window.location.href = url;
          }, 150);
        }
      });
    });
  });
</script>

